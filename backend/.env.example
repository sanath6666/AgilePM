# Local: mongodb://localhost:27017 (no DNS needed)
# Atlas: mongodb+srv://... requires working DNS (SRV lookup). If startup fails with
# "DNS operation timed out" / ConfigurationError, fix network/DNS or use Atlas's
# standard (non-SRV) connection string from Connect → Drivers.
MONGODB_URI=mongodb://localhost:27017
DB_NAME=agile_pm
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DUPLICATE_THRESHOLD=0.45
# If you change SBERT_MODEL_PATH or swap models, re-save bug embeddings (or expect mixed vectors).
SBERT_MODEL_PATH=
CORS_ORIGINS=http://localhost:3000
# Optional — GPT-assisted bug triage & delay narrative (503 on /ai/enhance-bug if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
